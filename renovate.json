{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>monkescience/renovate"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.ko\\.yaml$/"],
      "matchStrings": [
        "defaultBaseImage:\\s+(?<depName>[^:@\\s]+(?:/[^:@\\s]+)*):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
