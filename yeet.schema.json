{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/monkescience/yeet/main/yeet.schema.json",
  "title": "yeet configuration",
  "description": "Schema for .yeet.yaml",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "versioning": {
      "type": "string",
      "description": "Default versioning strategy for targets.",
      "enum": [
        "semver",
        "calver"
      ],
      "default": "semver"
    },
    "branch": {
      "type": "string",
      "description": "Default base branch for releases.",
      "minLength": 1,
      "default": "main"
    },
    "provider": {
      "type": "string",
      "description": "VCS provider. Use \"auto\" to detect from repository host or remote.",
      "enum": [
        "auto",
        "github",
        "gitlab"
      ],
      "default": "auto"
    },
    "pre_major_breaking_bumps_minor": {
      "type": "boolean",
      "description": "Before 1.0.0, breaking changes bump minor instead of major.",
      "default": true
    },
    "pre_major_features_bump_patch": {
      "type": "boolean",
      "description": "Before 1.0.0, features bump patch instead of minor.",
      "default": true
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "version_files": {
      "type": "array",
      "description": "Default version files for targets that do not override them.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "release": {
      "$ref": "#/$defs/release"
    },
    "changelog": {
      "$ref": "#/$defs/changelog"
    },
    "calver": {
      "$ref": "#/$defs/calver"
    },
    "targets": {
      "$ref": "#/$defs/targets"
    }
  },
  "required": [
    "targets"
  ],
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "remote": {
          "type": "string",
          "description": "Git remote name used for repository auto-detection when explicit coordinates are incomplete.",
          "minLength": 1,
          "default": "origin"
        },
        "host": {
          "type": "string",
          "description": "Repository host name, such as github.com or gitlab.company.com.",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "description": "Repository owner or namespace for GitHub-style repositories.",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "description": "Repository name for GitHub-style repositories.",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "description": "Full GitLab project path, including any subgroups.",
          "minLength": 1
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subject_include_branch": {
          "type": "boolean",
          "description": "Include target branch in generated release subjects.",
          "default": false
        },
        "auto_merge": {
          "type": "boolean",
          "description": "Automatically merge release PR/MR and finalize release in the same run.",
          "default": false
        },
        "auto_merge_force": {
          "type": "boolean",
          "description": "Bypass yeet readiness checks for auto-merge attempts. Provider branch rules still apply.",
          "default": false
        },
        "auto_merge_method": {
          "type": "string",
          "description": "Preferred merge method for auto-merge.",
          "enum": [
            "auto",
            "squash",
            "rebase",
            "merge"
          ],
          "default": "auto"
        },
        "pr_body_header": {
          "type": "string",
          "description": "Optional markdown inserted before changelog in release PR/MR body."
        },
        "pr_body_footer": {
          "type": "string",
          "description": "Optional markdown appended after changelog in release PR/MR body."
        }
      }
    },
    "changelog": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to changelog file.",
          "minLength": 1,
          "default": "CHANGELOG.md"
        },
        "include": {
          "type": "array",
          "description": "Conventional commit types to include in changelog.",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "feat",
            "fix",
            "perf",
            "revert"
          ]
        },
        "sections": {
          "type": "object",
          "description": "Mapping of commit types to section headings.",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "calver": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "description": "CalVer format string.",
          "minLength": 1,
          "default": "YYYY.0M.MICRO"
        }
      }
    },
    "targets": {
      "type": "object",
      "description": "Configured releasable targets in the repository.",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/target"
      }
    },
    "target": {
      "oneOf": [
        {
          "$ref": "#/$defs/path_target"
        },
        {
          "$ref": "#/$defs/derived_target"
        }
      ]
    },
    "path_target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "path"
        },
        "path": {
          "type": "string",
          "description": "Repo-relative path used for commit filtering.",
          "minLength": 1
        },
        "tag_prefix": {
          "type": "string",
          "description": "Stable tag namespace for this target.",
          "minLength": 1
        },
        "versioning": {
          "type": "string",
          "enum": [
            "semver",
            "calver"
          ]
        },
        "pre_major_breaking_bumps_minor": {
          "type": "boolean",
          "description": "Override the top-level pre_major_breaking_bumps_minor setting for this target."
        },
        "pre_major_features_bump_patch": {
          "type": "boolean",
          "description": "Override the top-level pre_major_features_bump_patch setting for this target."
        },
        "version_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "changelog": {
          "$ref": "#/$defs/changelog"
        },
        "calver": {
          "$ref": "#/$defs/calver"
        },
        "exclude_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "type",
        "path",
        "tag_prefix"
      ]
    },
    "derived_target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "derived"
        },
        "path": {
          "type": "string",
          "description": "Repo-relative path used for direct commit filtering.",
          "minLength": 1
        },
        "tag_prefix": {
          "type": "string",
          "description": "Stable tag namespace for this target.",
          "minLength": 1
        },
        "versioning": {
          "type": "string",
          "enum": [
            "semver",
            "calver"
          ]
        },
        "pre_major_breaking_bumps_minor": {
          "type": "boolean",
          "description": "Override the top-level pre_major_breaking_bumps_minor setting for this target."
        },
        "pre_major_features_bump_patch": {
          "type": "boolean",
          "description": "Override the top-level pre_major_features_bump_patch setting for this target."
        },
        "version_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "changelog": {
          "$ref": "#/$defs/changelog"
        },
        "calver": {
          "$ref": "#/$defs/calver"
        },
        "exclude_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "includes": {
          "type": "array",
          "description": "Path target IDs included in this derived release.",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "type",
        "includes",
        "tag_prefix"
      ]
    }
  }
}
